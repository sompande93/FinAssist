        <!-- Background Area: Success Metrics -->
        <mxCell id="metrics_box" value="Success Metrics &amp; Constraints:&#xa;- Latency: p90 &lt; 4s&#xa;- Accuracy: Zero hallucinations, grounded in data&#xa;- Auditability: 100% logging of all MCP calls &amp; KG queries&#xa;- Compliance: RBI + DPDP Act guidelines" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;fillColor=#fffde7;strokeColor=#fbc02d;fontStyle=1" vertex="1" parent="1">
